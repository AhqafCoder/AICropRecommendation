# ============================================================
# Environment Variables Template
# Copy this file to .env.local for development
# Copy this file to .env.production.local for production
# ============================================================

# ------------------------------------------------------------
# Clerk Authentication
# IMPORTANT: Use pk_test_* / sk_test_* for development only.
# Use pk_live_* / sk_live_* for production deployments.
# Using development keys on production exposes JWT tokens in
# URLs and routes auth through clerk.accounts.dev (insecure).
# See: https://clerk.com/docs/deployments/overview
# ------------------------------------------------------------

# Development (local):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Production:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
# CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# Clerk redirect URLs (optional – defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# ------------------------------------------------------------
# AI Services
# ------------------------------------------------------------
NEXT_PUBLIC_AI_API_URL=http://localhost:8000
NEXT_PUBLIC_DISEASE_API_URL=http://localhost:8001
